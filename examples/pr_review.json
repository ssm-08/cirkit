{
  "config": { "epsilon": 0.05, "max_iter": 8 },
  "sink": "out",
  "nodes": [
    { "id": "ctx",         "type": "battery",  "config": { "content": "Review the following pull request. Identify bugs, security risks, and quality issues.", "accumulate": false } },
    { "id": "writer",      "type": "motor",    "config": { "system": "Produce the initial code-review report. Focus on correctness and logic." } },
    { "id": "security",    "type": "motor",    "config": { "system": "Audit the PR for security issues. Output HIGH confidence only if you found NO vulnerabilities." } },
    { "id": "filter",      "type": "resistor", "config": { "threshold": 0.55 } },
    { "id": "gate",        "type": "and_gate", "config": { "threshold": 0.55, "early_exit_threshold": 0.9, "merge_mode": "synthesize" } },
    { "id": "synthesizer", "type": "motor",    "config": { "system": "Fuse the inputs into one coherent final code-review report. Do not editorialize. Preserve all findings." } },
    { "id": "out",         "type": "sink",     "config": {} }
  ],
  "wires": [
    { "from": "ctx",         "to": "writer",      "role": "context"  },
    { "from": "ctx",         "to": "security",    "role": "context"  },
    { "from": "writer",      "to": "filter",      "role": "context"  },
    { "from": "filter",      "to": "gate",        "role": "peer"     },
    { "from": "security",    "to": "gate",        "role": "peer"     },
    { "from": "gate",        "to": "synthesizer", "role": "context"  },
    { "from": "synthesizer", "to": "out",         "role": "context"  },
    { "from": "gate",        "to": "writer",      "role": "feedback" },
    { "from": "gate",        "to": "security",    "role": "feedback" }
  ]
}
